# Barrel/export index files accumulate one export line per component. During the
# 1.0.0 build-out, many component branches each append to the same barrel, so use
# git's built-in union merge driver to auto-keep both sides instead of conflicting.
packages/canopy/src/index.ts          merge=union
packages/canopy/src/seeds/index.ts    merge=union
packages/canopy/src/twigs/index.ts    merge=union
packages/canopy/src/branches/index.ts merge=union
