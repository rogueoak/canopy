# Storybook's preset loader resolves modules from the project root rather than the
# app's nested node_modules. Under pnpm's isolated layout that breaks preset
# resolution (e.g. @storybook/react-vite/preset), so hoist Storybook packages
# to the root node_modules. See https://github.com/storybookjs/storybook/issues/22431
public-hoist-pattern[]=*storybook*
public-hoist-pattern[]=@storybook/*
