{
  "name": "@rogueoak/canopy",
  "version": "0.0.0",
  "description": "Canopy components - built on Roots tokens, Tailwind v4, Radix/shadcn (later).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogueoak/canopy.git",
    "directory": "packages/canopy"
  },
  "homepage": "https://github.com/rogueoak/canopy/tree/main/packages/canopy#readme",
  "bugs": {
    "url": "https://github.com/rogueoak/canopy/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./seeds": {
      "types": "./dist/seeds/index.d.ts",
      "import": "./dist/seeds/index.js"
    },
    "./twigs": {
      "types": "./dist/twigs/index.d.ts",
      "import": "./dist/twigs/index.js"
    },
    "./branches": {
      "types": "./dist/branches/index.d.ts",
      "import": "./dist/branches/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@rogueoak/roots": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
