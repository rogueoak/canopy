      "$type": "duration",
      "$description": "Micro-interactions (hover, small state changes)."
    },
    "base": {
      "$value": "200ms",
      "$type": "duration",
      "$description": "Default UI transitions."
    },
    "slow": {
      "$value": "320ms",
      "$type": "duration",
      "$description": "Larger surfaces (overlays, drawers)."
    }
  },
  "ease": {
    "standard": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)",
      "$type": "cubicBezier",
