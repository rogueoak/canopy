{
  "color": {
    "bg": {
      "$value": "{color.stone.50}",
      "$type": "color",
      "$description": "App background / page canvas."
    },
    "surface": {
      "$value": "{color.base.white}",
      "$type": "color",
      "$description": "Default surface (cards, panels)."
    },
    "surface-raised": {
      "$value": "{color.base.white}",
      "$type": "color",
      "$description": "Raised surface (popovers, menus) — distinguished by elevation."
    },
    "overlay": {
      "$value": "{color.stone.900}",
      "$type": "color",
      "$description": "Scrim/overlay base (used at reduced opacity behind modals)."
    },
    "text": {
      "$value": "{color.stone.900}",
      "$type": "color",
      "$description": "Default body text."
    },
    "text-muted": {
      "$value": "{color.stone.600}",
      "$type": "color",
      "$description": "Muted/secondary text."
    },
    "text-subtle": {
      "$value": "{color.stone.500}",
      "$type": "color",
      "$description": "Subtle/tertiary text (captions, placeholders)."
    },
    "text-inverted": {
      "$value": "{color.stone.50}",
      "$type": "color",
      "$description": "Text on dark/inverted surfaces."
    },
    "border": {
      "$value": "{color.stone.200}",
      "$type": "color",
      "$description": "Default hairline border."
    },
    "border-strong": {
      "$value": "{color.stone.300}",
      "$type": "color",
      "$description": "Stronger border / divider."
    },
    "ring": {
      "$value": "{color.moss.600}",
      "$type": "color",
      "$description": "Focus ring."
    },
    "ring-offset": {
      "$value": "{color.base.white}",
      "$type": "color",
      "$description": "Focus-ring offset / gap colour — sits between a focus ring and the element on a coloured surface (defaults to the page surface). Pairs with ring."
    },
    "primary": {
      "$value": "{color.moss.600}",
      "$type": "color",
      "$description": "Primary brand role (buttons, active states)."
    },
    "primary-foreground": {
      "$value": "{color.moss.50}",
      "$type": "color",
      "$description": "Foreground on primary surfaces."
    },
    "primary-hover": {
      "$value": "{color.moss.700}",
      "$type": "color",
      "$description": "Primary role — hover state (deeper ramp step in light, lighter in dark)."
    },
    "primary-active": {
      "$value": "{color.moss.800}",
      "$type": "color",
      "$description": "Primary role — active/pressed state."
    },
    "secondary": {
      "$value": "{color.bark.600}",
      "$type": "color",
      "$description": "Secondary role."
    },
    "secondary-foreground": {
      "$value": "{color.bark.50}",
      "$type": "color",
      "$description": "Foreground on secondary surfaces."
    },
    "secondary-hover": {
      "$value": "{color.bark.700}",
      "$type": "color",
      "$description": "Secondary role — hover state."
    },
    "secondary-active": {
      "$value": "{color.bark.800}",
      "$type": "color",
      "$description": "Secondary role — active/pressed state."
    },
    "accent": {
      "$value": "{color.amber.500}",
      "$type": "color",
      "$description": "Accent role — FILL use only (amber.500 is ~2.83:1 on bg, below AA for foreground). For accent text/icon/border on a light surface use accent-strong."
    },
    "accent-strong": {
      "$value": "{color.amber.700}",
      "$type": "color",
      "$description": "Accent for FOREGROUND use (text/icon/border) on light surfaces — amber.700 reaches AA (~6.15:1 on bg). accent stays the fill role."
    },
    "accent-foreground": {
      "$value": "{color.amber.950}",
      "$type": "color",
      "$description": "Foreground on accent (fill) surfaces."
    },
    "accent-hover": {
      "$value": "{color.amber.400}",
      "$type": "color",
      "$description": "Accent role — hover state. accent is a fill role with a near-black foreground (accent-foreground = amber.950), so its hover lightens (amber.500 → .400) rather than darkening: amber.600 dropped the foreground to ~3.79:1 (below AA), amber.400 restores it to ~6.40:1 (feedback 0003)."
    },
    "muted": {
      "$value": "{color.stone.100}",
      "$type": "color",
      "$description": "Muted surface (subtle fills, hover backgrounds)."
    },
    "muted-foreground": {
      "$value": "{color.stone.600}",
      "$type": "color",
      "$description": "Foreground on muted surfaces."
    },
    "muted-raised": {
      "$value": "{color.stone.100}",
      "$type": "color",
      "$description": "Highlight/hover fill for items on a RAISED surface (popovers, menus) — a subtle lift on the white raised surface (feedback 0006). Steps toward the foreground on surface-raised in BOTH themes, unlike base muted which inverts on a raised surface in dark (muted stone.900 is darker than surface-raised stone.800, so the highlight recedes). Pairs with text/text-text at AA."
    },
    "success": {
      "DEFAULT": {
        "$value": "{color.success.600}",
        "$type": "color",
        "$description": "Success status role. Lives at .DEFAULT (sibling of the success ramp steps) so it emits --color-success (→ bg-success) without colliding with the color.success ramp group."
      }
    },
    "success-foreground": {
      "$value": "{color.success.50}",
      "$type": "color",
      "$description": "Foreground on success surfaces."
    },
    "warning": {
      "DEFAULT": {
        "$value": "{color.warning.600}",
        "$type": "color",
        "$description": "Warning status role (see success.DEFAULT note)."
      }
    },
    "warning-foreground": {
      "$value": "{color.warning.50}",
      "$type": "color",
      "$description": "Foreground on warning surfaces."
    },
    "danger": {
      "DEFAULT": {
        "$value": "{color.danger.600}",
        "$type": "color",
        "$description": "Danger/error status role (see success.DEFAULT note)."
      }
    },
    "danger-foreground": {
      "$value": "{color.danger.50}",
      "$type": "color",
      "$description": "Foreground on danger surfaces."
    },
    "danger-hover": {
      "$value": "{color.danger.700}",
      "$type": "color",
      "$description": "Danger role — hover state."
    },
    "danger-active": {
      "$value": "{color.danger.800}",
      "$type": "color",
      "$description": "Danger role — active/pressed state. Deepens 600 → 700 → 800 like primary/secondary so the destructive button gives press feedback; near-white danger-foreground (danger.50) stays well above AA on the darker fill."
    },
    "disabled": {
      "$value": "{color.stone.100}",
      "$type": "color",
      "$description": "Disabled surface — a muted fill for disabled controls. Pairs with disabled-foreground; components may also use opacity where a control just dims."
    },
    "disabled-foreground": {
      "$value": "{color.stone.400}",
      "$type": "color",
      "$description": "Foreground (text/icon) on disabled surfaces."
    },
    "info": {
      "DEFAULT": {
        "$value": "{color.info.600}",
        "$type": "color",
        "$description": "Info status role (see success.DEFAULT note)."
      }
    },
    "info-foreground": {
      "$value": "{color.info.50}",
      "$type": "color",
      "$description": "Foreground on info surfaces."
    }
  }
}
