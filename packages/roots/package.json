{
  "name": "@rogueoak/roots",
  "version": "0.0.0",
  "description": "Canopy design tokens — Style Dictionary pipeline (CSS vars, typed TS, Tailwind v4 preset).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogueoak/canopy.git",
    "directory": "packages/roots"
  },
  "homepage": "https://github.com/rogueoak/canopy/tree/main/packages/roots#readme",
  "bugs": {
    "url": "https://github.com/rogueoak/canopy/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "brand.mjs",
    "cli.mjs",
    "contrast.mjs",
    "style-dictionary.config.mjs",
    "examples"
  ],
  "bin": {
    "roots-brand": "./cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tailwind-preset.css": "./dist/tailwind-preset.css",
    "./brand": "./brand.mjs"
  },
  "scripts": {
    "build": "pnpm clean && node build.mjs && tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "style-dictionary": "^4.3.0"
  },
  "peerDependenciesMeta": {
    "style-dictionary": {
      "optional": true
    }
  },
  "devDependencies": {
    "style-dictionary": "^4.3.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
